# API Keys (AI Plus Package only)
# Get OpenAI key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_key_here

# Or use Anthropic Claude from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_key_here

# LLM Settings
LLM_PROVIDER=openai  # 'openai' or 'anthropic'
LLM_MODEL=gpt-4      # or 'claude-3-sonnet-20240229'

# Application Settings
APP_ENV=development
LOG_LEVEL=INFO

# Database
DB_PATH=data/inventory.db


# Thresholds
LOW_STOCK_THRESHOLD=10
REORDER_POINT_MULTIPLIER=1.5

# Payment Configuration (Optional - for subscription features)
# Razorpay (India) - Get from: https://dashboard.razorpay.com/
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_PLAN_PROFESSIONAL=plan_professional_id
RAZORPAY_PLAN_AI_PLUS=plan_ai_plus_id

# Stripe (International) - Get from: https://dashboard.stripe.com/
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PRICE_PROFESSIONAL=price_professional_id
STRIPE_PRICE_AI_PLUS=price_ai_plus_id
